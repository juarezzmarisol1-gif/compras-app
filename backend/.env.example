# ── Google Sheets ─────────────────────────────────────────────────────────────
# ID del spreadsheet (de la URL: /d/{SHEET_ID}/edit)
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Opción A: ruta al archivo JSON de la service account (desarrollo local)
GOOGLE_SERVICE_ACCOUNT_JSON=./service_account.json

# Opción B: contenido JSON completo como string (producción en Vercel)
# GOOGLE_SERVICE_ACCOUNT_INFO={"type":"service_account","project_id":...}

# ── CORS ──────────────────────────────────────────────────────────────────────
# Desarrollo: dejar como está. Producción: reemplazar con URL de Netlify.
ALLOWED_ORIGINS=http://localhost:5173
